# MongoDB connection string
# Local:  mongodb://localhost:27017/clickshq
# Atlas:  mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/clickshq
# On Payload Cloud this is set automatically.
DATABASE_URI=mongodb://localhost:27017/clickshq

# A long random string used to sign JWTs. Change this in production!
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public URL of the site (used for CORS, SEO, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
